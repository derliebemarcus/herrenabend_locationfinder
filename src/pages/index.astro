---
import LocationApp from '../components/LocationApp.tsx';
import '../styles/global.css';

const apiKey = import.meta.env.PUBLIC_GOOGLE_PLACES_API_KEY;
---

<html lang="de" class="antialiased">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>Herrenabend Locationfinder</title>
    
    <meta name="theme-color" content="#1a202c" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />

    <!-- Google Maps JS API -->
    {apiKey && (
      <script src={`https://maps.googleapis.com/maps/api/js?key=${apiKey}&libraries=places`} async defer></script>
    )}
  </head>
  <body class="bg-gray-50 text-gray-900 dark:bg-gray-900 dark:text-gray-100 min-h-screen flex flex-col items-center justify-center p-4 selection:bg-blue-500 selection:text-white transition-colors duration-300">
    <main class="w-full max-w-md mx-auto">
      <header class="text-center mb-10">
        <h1 class="text-4xl font-extrabold tracking-tight text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-purple-600 dark:from-blue-400 dark:to-purple-400 mb-2">
          Locationfinder
        </h1>
        <p class="text-gray-500 dark:text-gray-400 text-sm font-medium">Finde die nächste Bar für den Herrenabend.</p>
      </header>

      <LocationApp client:load />
    </main>

    {!apiKey && (
      <div class="fixed bottom-0 left-0 w-full bg-red-600 text-white text-center p-3 text-sm font-bold shadow-lg z-50">
        Google Places API Key fehlt! Bitte in der .env Datei als PUBLIC_GOOGLE_PLACES_API_KEY eintragen.
      </div>
    )}
  </body>
</html>
